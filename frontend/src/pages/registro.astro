---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegisterForm from "../components/auth/RegisterForm";
---

<BaseLayout title="Crear cuenta - Tienda Alcora">
  <section class="bg-bg-light min-h-[80vh]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      {/* Header */}
      <div class="text-center mb-8">
        <a href="/">
          <img src="/logo-alcora.svg" alt="Alcora" class="h-10 mx-auto mb-4" />
        </a>
        <h1 class="text-2xl lg:text-3xl font-bold text-navy">
          Crear una cuenta
        </h1>
        <p class="text-text-muted mt-2 max-w-xl mx-auto">
          Registrese como particular o como empresa profesional.
          Las cuentas de empresa requieren validacion por un administrador.
        </p>
      </div>

      {/* Features strip */}
      <div class="flex flex-wrap justify-center gap-6 mb-8 text-sm text-text-muted">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-action" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          Datos seguros y protegidos
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-action" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
          </svg>
          Compra facil y rapida
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-action" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Precios profesionales para empresas
        </div>
      </div>

      {/* Form card - wide */}
      <div class="bg-white border border-border rounded-xl p-6 sm:p-8 lg:p-10 shadow-sm">
        <RegisterForm client:load />
      </div>
    </div>
  </section>
</BaseLayout>
