---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/blog/ArticleCard.astro";
import InfiniteArticleGrid from "../../components/blog/InfiniteArticleGrid.tsx";
import { getArticulos } from "../../lib/directus";

const { data: articles, meta } = await getArticulos({ page: 1, limit: 9 });
const hasMore = meta.total_count > 9;

const categories = [
  { slug: "guia", label: "Guia" },
  { slug: "consejo", label: "Consejo" },
  { slug: "producto", label: "Producto" },
  { slug: "noticia", label: "Noticia" },
];
---

<BaseLayout
  title="Blog - Alcora Salud Ambiental"
  description="Guias, consejos y novedades sobre salud ambiental, control de plagas y limpieza profesional"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {/* Page header */}
    <h1 class="text-2xl font-bold text-navy mb-2">Blog</h1>
    <p class="text-sm text-text-muted mb-6">Guias, consejos y novedades sobre salud ambiental</p>

    {/* Category navigation */}
    <div class="flex items-center gap-2 mb-8 overflow-x-auto pb-2">
      <a
        href="/blog"
        class="px-3 py-1.5 text-sm rounded-full border bg-action text-white border-action transition-colors flex-shrink-0"
      >
        Todos
      </a>
      {categories.map((cat) => (
        <a
          href={`/blog/${cat.slug}`}
          class="px-3 py-1.5 text-sm rounded-full border border-border text-text-muted hover:text-action hover:border-action transition-colors flex-shrink-0"
        >
          {cat.label}
        </a>
      ))}
    </div>

    {/* Article grid */}
    {articles.length > 0 ? (
      <>
        {/* Initial SSR grid */}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {articles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>

        {/* Infinite scroll for pages 2+ */}
        {hasMore && (
          <div class="mt-8">
            <InfiniteArticleGrid
              client:load
              apiUrl="/blog-api"
              initialItems={[]}
              initialPage={1}
              initialHasMore={hasMore}
            />
          </div>
        )}
      </>
    ) : (
      <div class="text-center py-16">
        <svg class="w-16 h-16 mx-auto mb-4 text-border" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
        <p class="text-sm text-text-muted">No hay articulos publicados</p>
      </div>
    )}
  </div>
</BaseLayout>
