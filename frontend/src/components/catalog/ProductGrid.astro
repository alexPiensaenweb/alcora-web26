---
import ProductCard from "./ProductCard.astro";
import type { Producto, TarifaEspecial } from "../../lib/types";
import { resolveDiscount, calculatePrice, calculateB2CPrice } from "../../lib/pricing";

interface Props {
  products: Producto[];
  tarifas?: TarifaEspecial[];
  isLoggedIn?: boolean;
  isProfessional?: boolean;
}

const { products, tarifas = [], isLoggedIn = false, isProfessional = false } = Astro.props;
---

{products.length === 0 ? (
  <div class="text-center py-12 text-text-muted">
    <svg class="w-16 h-16 mx-auto mb-4 text-border" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
    </svg>
    <p class="text-sm">No se encontraron productos.</p>
  </div>
) : (
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
    {products.map((product) => {
      let price: number | null = null;
      let priceLabel: string | null = null;

      if (isProfessional && isLoggedIn && tarifas.length > 0) {
        const categoriaId = typeof product.categoria === "object" ? product.categoria?.id : product.categoria;
        const descuento = resolveDiscount(tarifas, product.id, categoriaId || null);
        price = calculatePrice(product.precio_base, descuento);
        priceLabel = 'sin IVA';
      } else if (isProfessional && isLoggedIn) {
        price = product.precio_base;
        priceLabel = 'sin IVA';
      } else if (product.segmento_venta !== 'b2b') {
        // Visitor or particular: show B2C price
        price = calculateB2CPrice(product.precio_base, product.tipo_iva || 21);
        priceLabel = 'IVA incluido';
      }
      // b2b product for non-professional: no price (shouldn't happen with segmento filter)

      return <ProductCard product={product} price={price} priceLabel={priceLabel} />;
    })}
  </div>
)}
